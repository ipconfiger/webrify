# Rust
/target
**/*.rs.bk

# Cargo.lock IS committed (binary crate, AGENTS.md mandates lockfiles).

# Node / frontend
node_modules/
# Build artifacts under dist/ are ignored, but the committed placeholder
# files are kept so rust-embed has a target to embed at compile time
# (review BLOCKER fix) even in a fresh clone before the first Vite build.
packages/turnstile-widget/dist/*
!packages/turnstile-widget/dist/.gitkeep
!packages/turnstile-widget/dist/index.html
# wasm pkg copied into the widget by the build-widget recipe (regenerated)
packages/turnstile-widget/wasm/

# wasm-pack output
/pkg/

# ts-rs generated TypeScript bindings (regenerated by `cargo test`)
crates/*/bindings/

# Deepwork orchestrator session state (not committed; readable via .ignore)
.slim/deepwork/

# Playwright MCP artifacts (browser snapshots/screenshots from E2E runs)
.playwright-mcp/

# Editor / OS
.idea/
.vscode/
*.swp
.DS_Store

# Env / secrets
.env
.env.*
!.env.example

# Logs
*.log
